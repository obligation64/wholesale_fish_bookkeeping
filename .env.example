# 存储模式配置
# 可选值: local(本地SQLite), cloud(云开发), hybrid(混合模式-本地为主,云端同步)
STORAGE_MODE=local

# 腾讯云开发配置
# 获取方式: 访问 https://console.cloud.tencent.com/cam/capi

# 腾讯云API密钥Secret ID(仅在cloud或hybrid模式下需要)
TCB_SECRET_ID=your-secret-id-here

# 腾讯云API密钥Secret Key(仅在cloud或hybrid模式下需要)
TCB_SECRET_KEY=your-secret-key-here
